# ============================================================
# AI Chatbot MVP 环境变量
# ============================================================
# 复制此文件为 .env 后填入实际值
# .env 文件不会被提交到 Git

# 服务端端口（默认 3001）
PORT=3001

# OpenAI API Key（可选）
# 不设置则自动启用 Mock 模式
# OPENAI_API_KEY=sk-your-api-key-here

# OpenAI 模型（可选，默认 gpt-4o-mini）
# OPENAI_MODEL=gpt-4o-mini

# OpenAI Base URL（可选，用于兼容 API）
# OPENAI_BASE_URL=https://api.openai.com/v1
